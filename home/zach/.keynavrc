# $HOME/.keynavrc

clear

super+semicolon start
ctrl+r restart
Tab restart
Escape end
ctrl+g end
q end
a history-back
space warp,click 1,end
Return warp,click 1,end
semicolon warp,end
w windowzoom
c cursorzoom 200 200

1 click 1
2 click 2
3 click 3

i warp,doubleclick 1,end
o warp,click 3,end
4 warp,click 4
5 warp,click 5

h cut-left
j cut-down
k cut-up
l cut-right
shift+h move-left
shift+j move-down
shift+k move-up
shift+l move-right
ctrl+h cut-left
ctrl+j cut-down
ctrl+k cut-up
ctrl+l cut-right
y cut-left,cut-up
u cut-right,cut-up
b cut-left,cut-down
n cut-right,cut-down
shift+y move-left,move-up
shift+u move-right,move-up
shift+b move-left,move-down
shift+n move-right,move-down
ctrl+y cut-left,cut-up
ctrl+u cut-right,cut-up
ctrl+b cut-left,cut-down
ctrl+n cut-right,cut-down
